# Másold .env-be: cp .env.example .env
# A .env SOHA nem kerül a repóba (lásd .gitignore).

# Kötelező - az AI Agent ezt használja (2. fázistól).
ANTHROPIC_API_KEY="sk-ant-..."

# Opcionális - alapértelmezett: claude-sonnet-5. Költségérzékeny futtatáshoz
# pl. claude-haiku-4-5 is beállítható.
ANTHROPIC_MODEL="claude-sonnet-5"

# Opcionális - alapértelmezett: data/smartbasket.db
SMARTBASKET_DB_PATH="data/smartbasket.db"

# Opcionális - alapértelmezett a hivatalos GVH Árfigyelő napi Excel URL-je.
ARFIGYELO_DAILY_XLSX_URL="https://cdnarfigyeloprodweu.azureedge.net/excel/arfigyelo_napi_termekadatok.xlsx"
