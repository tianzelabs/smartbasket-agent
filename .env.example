# Másold .env-be: cp .env.example .env
# A .env SOHA nem kerül a repóba (lásd .gitignore).

# Kötelező - az AI Agent ezt használja (2. fázistól).
ANTHROPIC_API_KEY="sk-ant-..."

# Opcionális - alapértelmezett: claude-sonnet-5. Költségérzékeny futtatáshoz
# pl. claude-haiku-4-5 is beállítható.
ANTHROPIC_MODEL="claude-sonnet-5"

# Kötelező - két kapcsolat, két jog (docs/db-migration-rationale.md).
# Előbb: docker compose up -d (lokális Postgres, OrbStack vagy Docker Desktop).
# READ-WRITE: a migráció és a napi import ezzel ír.
DATABASE_URL="postgresql://smartbasket:smartbasket@localhost:5432/smartbasket"
# READ-ONLY: az agent runSql/listCategories toolja ezen fut, csak SELECT -
# a smartbasket_ro szerepkör jogosultsága ezt a DB szerveren is kikényszeríti.
DATABASE_URL_READONLY="postgresql://smartbasket_ro:smartbasket_ro@localhost:5432/smartbasket"

# Opcionális - alapértelmezett a hivatalos GVH Árfigyelő napi Excel URL-je.
ARFIGYELO_DAILY_XLSX_URL="https://cdnarfigyeloprodweu.azureedge.net/excel/arfigyelo_napi_termekadatok.xlsx"
